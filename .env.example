# TrueRise / Rectify — environment template
# ---------------------------------------------------------------------------
# This file is a TEMPLATE. It is committed to Git. Copy it to `.env` (which
# is git-ignored) and fill it with your local/CI values:
#
#   cp .env.example .env
#
# The Flutter app does NOT read `.env` at runtime. There is no dotenv loader.
# This file exists so developers/CI have a single place to keep the values
# they will pass to `flutter run` / `flutter build` via `--dart-define`,
# e.g.:
#
#   flutter run \
#     --dart-define=RECTIFY_ENV=dev \
#     --dart-define=RECTIFY_PROXY_BASE_URL=https://proxy.example.invalid \
#     --dart-define=RECTIFY_PROXY_APP_ID=rectify-dev-public-app-id
#
# A common pattern is to source these into shell vars and forward them:
#
#   set -a; source .env; set +a
#   flutter run \
#     --dart-define=RECTIFY_ENV="$RECTIFY_ENV" \
#     --dart-define=RECTIFY_PROXY_BASE_URL="$RECTIFY_PROXY_BASE_URL" \
#     --dart-define=RECTIFY_PROXY_APP_ID="$RECTIFY_PROXY_APP_ID"
#
# SECURITY — READ BEFORE ADDING ANY KEY HERE
# ---------------------------------------------------------------------------
# Per docs/implementation-plan.md Appendix B: every value passed via
# `--dart-define` is compiled into the released IPA / APK as a plain string
# and is trivially recoverable with off-the-shelf tools. Therefore NOTHING
# in this file is a confidential secret. Only public configuration values
# belong here (public URLs, public app identifiers, URL/bundle-id-restricted
# `pk.…` tokens, non-credential build flags).
#
# Confidential secrets (production rectification provider API key, Mapbox
# `sk.…` tokens, Google Places billing keys, third-party billing
# credentials, signing keystore passwords) MUST NEVER be placed here, in
# the source tree, in `--dart-define`, in `firebase_options.dart`, in any
# asset file, or in any committed config. They live server-side in the
# proxy's secret store (see implementation-plan.md §9.7).
# ---------------------------------------------------------------------------


# ----- Proxy mode (data/api/api_client.dart + providers/core_providers.dart) -----

# Build flag — switches Logger verbosity / Crashlytics enablement.
# One of: dev | staging | prod
RECTIFY_ENV=dev

# Base URL of the Rectify backend proxy. Public URL, no secret.
# Leave blank to keep the app on the local stub / demo-only path.
RECTIFY_PROXY_BASE_URL=

# Optional path prefix appended to the proxy base URL.
RECTIFY_PROXY_PATH=

# Public app identifier sent in the AuthInterceptor for soft routing and
# rate-limit accounting on the proxy. NOT a confidential secret — see
# Appendix B. Rotatable by shipping a new build.
RECTIFY_PROXY_APP_ID=


# ----- Geocoding (lib/data/geocoding/, post-MVP) -----

# Public URL of the geocoding provider (e.g. https://api.mapbox.com).
RECTIFY_GEOCODING_BASE_URL=

# PUBLIC, URL- and bundle-id-restricted client token (e.g. Mapbox `pk.…`).
# NEVER a Mapbox `sk.…` token, NEVER a Google Places billing key, NEVER any
# credential that is not server-side-restricted to this app's URL/bundle.
# Leave blank to route geocoding through the proxy instead.
RECTIFY_GEOCODING_PUBLIC_KEY=
