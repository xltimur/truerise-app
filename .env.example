# TrueRise / Rectify — environment template
# ---------------------------------------------------------------------------
# This file is a TEMPLATE for the bundled `.env`. Copy it and fill in your
# values:
#
#   cp .env.example .env
#
# The Flutter app DOES read `.env` at runtime via `flutter_dotenv`
# (see lib/main.dart). The file is bundled as a Flutter asset
# (pubspec.yaml -> flutter.assets), so its contents are baked into the
# released APK / IPA. Per `--dart-define`-style guidance below this is
# trivially recoverable from the binary — use it for DEMO / REVIEW builds
# with a low-budget astrology-api.io key, not for a production rollout.
#
# Runtime override hierarchy (lib/providers/core_providers.dart):
#   1. End-user-supplied key in Settings -> flutter_secure_storage
#   2. ASTRO_API_KEY from this bundled `.env`
#   3. null -> proxy mode (see RECTIFY_PROXY_BASE_URL)
#
# Other RECTIFY_* values below are still passed via `--dart-define` at
# build time; the .env file holds them as a single source for the build
# command:
#
#   set -a; source .env; set +a
#   flutter run \
#     --dart-define=RECTIFY_ENV="$RECTIFY_ENV" \
#     --dart-define=RECTIFY_PROXY_BASE_URL="$RECTIFY_PROXY_BASE_URL" \
#     --dart-define=RECTIFY_PROXY_APP_ID="$RECTIFY_PROXY_APP_ID"
#
# SECURITY
# ---------------------------------------------------------------------------
# Anything in this file (especially ASTRO_API_KEY) is shipped inside the
# APK as an asset and is recoverable from the binary. Use a key whose
# usage you are comfortable exposing to reviewers — never a production
# key with elevated quota or billing. For production, rip ASTRO_API_KEY
# out of `.env`, ship the proxy-mode build, and keep the real provider
# key server-side in the proxy's secret store
# (see implementation-plan.md §9.7).
# ---------------------------------------------------------------------------


# ----- Bundled provider key (loaded by flutter_dotenv at app start) -----

# astrology-api.io API key. Sent as `Authorization: Bearer <ASTRO_API_KEY>`
# against RECTIFY_PROVIDER_BASE_URL + RECTIFY_PROVIDER_PATH whenever the
# end user has not entered their own key in Settings. Leave blank to
# force proxy mode.
ASTRO_API_KEY=


# ----- Proxy mode (data/api/api_client.dart + providers/core_providers.dart) -----

# Build flag — switches Logger verbosity / Crashlytics enablement.
# One of: dev | staging | prod
RECTIFY_ENV=dev

# Base URL of the Rectify backend proxy. Public URL, no secret.
# Leave blank to keep the app on the local stub / demo-only path.
RECTIFY_PROXY_BASE_URL=

# Optional path prefix appended to the proxy base URL.
RECTIFY_PROXY_PATH=

# Public app identifier sent in the AuthInterceptor for soft routing and
# rate-limit accounting on the proxy. NOT a confidential secret — see
# Appendix B. Rotatable by shipping a new build.
RECTIFY_PROXY_APP_ID=


# ----- Provider-direct mode (lib/providers/core_providers.dart) -----
# These are PUBLIC configuration values — they are baked into the binary.
# The astrology-api.io key itself is ASTRO_API_KEY above (loaded via
# flutter_dotenv) OR a value the end user enters in the in-app Settings
# sheet (stored in flutter_secure_storage, takes priority).

# Base URL of the rectification provider (used in providerDirect auth mode).
# Defaults to https://api.astrology-api.io — override only if you self-host
# a compatible API or use a test double.
RECTIFY_PROVIDER_BASE_URL=https://api.astrology-api.io

# Endpoint path for POST rectification/search.
# Default: /api/v3/rectification/search
RECTIFY_PROVIDER_PATH=/api/v3/rectification/search


# ----- Geocoding (lib/data/geocoding/, post-MVP) -----

# Public URL of the geocoding provider (e.g. https://api.mapbox.com).
RECTIFY_GEOCODING_BASE_URL=

# PUBLIC, URL- and bundle-id-restricted client token (e.g. Mapbox `pk.…`).
# NEVER a Mapbox `sk.…` token, NEVER a Google Places billing key, NEVER any
# credential that is not server-side-restricted to this app's URL/bundle.
# Leave blank to route geocoding through the proxy instead.
RECTIFY_GEOCODING_PUBLIC_KEY=
